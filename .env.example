NODE_ENV=development
PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Writable server runtime directory for auth/email previews and audit files.
SPAREKART_RUNTIME_DIR=.sparekart-runtime

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB_NAME=sparekart

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=SpareKart

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT auth
JWT_SECRET=change-this-to-a-long-random-secret-with-at-least-32-characters

# Auth + seeded dev accounts
SPAREKART_SEED_PASSWORD=SpareKart123!
SPAREKART_SUPERADMIN_EMAIL=sparekart302@gmail.com
SPAREKART_SUPERADMIN_PASSWORD=sparekart302
